# ======================================================================
# Copy this file to `.env` and fill in the real values.
# The backend reads these as environment variables (see application.yml).
# NEVER commit the real .env file.
# ======================================================================

# --- Database (Supabase PostgreSQL) -----------------------------------
# Supabase Dashboard → Project Settings → Database → Connection string.
# Use the *Session pooler* URI (port 5432) for a plain JDBC connection:
#   jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
DATABASE_USERNAME=postgres.<your-project-ref>
DATABASE_PASSWORD=<your-database-password>

# --- Security ----------------------------------------------------------
# At least 32 characters. Generate: openssl rand -base64 48
JWT_SECRET=<random-string-at-least-32-chars>

# Admin account, created automatically at first startup
ADMIN_EMAIL=tranvuthien1708@gmail.com
ADMIN_PASSWORD=<strong-password>

# Send the refresh cookie only over HTTPS (true in production)
COOKIE_SECURE=true

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Contact-form email notifications (Gmail SMTP) ---------------------
# Optional: leave MAIL_USERNAME empty to disable notifications.
# MAIL_PASSWORD is a Gmail App Password (NOT your account password):
#   Google Account -> Security -> 2-Step Verification -> App passwords
MAIL_USERNAME=<your-gmail-address>
MAIL_PASSWORD=<16-char-gmail-app-password>
# Where notifications are sent; defaults to ADMIN_EMAIL when unset
CONTACT_NOTIFY_TO=

# --- Supabase Storage (admin image uploads) ----------------------------
# STORAGE_PROVIDER: "supabase" (default) or "local" (saves to ./uploads)
STORAGE_PROVIDER=supabase
# Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
# service_role secret key — KEEP SERVER-SIDE ONLY
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# A PUBLIC storage bucket for images (create it in Supabase → Storage)
SUPABASE_STORAGE_BUCKET=portfolio
